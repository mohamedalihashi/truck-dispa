PORT=4000
CLIENT_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,https://truck-dispa.vercel.app
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/truckdispatch?sslmode=disable

# Auth email OTP for register/login (false = create session immediately, no code step)
AUTH_OTP_ENABLED=false

# Gmail OTP (create App Password: Google Account → Security → 2-Step Verification → App passwords)
EMAIL_DEV_MODE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=TruckDispatch <your@gmail.com>

# WaafiPay — mobile wallet payments (EVC / ZAAD)
WAAFI_MERCHANT_UID=your-merchant-uid
WAAFI_API_USER_ID=your-api-user-id
WAAFI_API_KEY=your-waafi-api-key
WAAFI_API_URL=https://api.waafipay.net/asm
WAAFI_CURRENCY=SLSH
WAAFI_DEV_MOCK=false

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Backend SMS provider and public feedback links
SMS_API_URL=https://xxxxx.api.infobip.com
SMS_API_KEY=replace-with-provider-api-key
SMS_SENDER_ID=ServiceSMS
APP_PUBLIC_URL=http://localhost:5173
