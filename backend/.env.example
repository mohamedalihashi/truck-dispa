PORT=4000
# Comma-separated browser origins allowed to call the API (no trailing slash)
CLIENT_ORIGIN=https://truck-dispa.vercel.app
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Managed Postgres connection string (Neon / Supabase / Railway / etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Auth email OTP — keep true in production
AUTH_OTP_ENABLED=true

# Gmail OTP (Google Account → Security → 2-Step Verification → App passwords)
EMAIL_DEV_MODE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=TruckDispatch <your@gmail.com>

# WaafiPay — mobile wallet payments (EVC / ZAAD). Never leave mock on in production.
WAAFI_MERCHANT_UID=your-merchant-uid
WAAFI_API_USER_ID=your-api-user-id
WAAFI_API_KEY=your-waafi-api-key
WAAFI_API_URL=https://api.waafipay.net/asm
WAAFI_CURRENCY=SLSH
WAAFI_DEV_MOCK=false

# Cloudinary — REQUIRED on Vercel (POD, avatars, license/truck docs)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMS provider + public feedback links phones can open
SMS_API_URL=https://xxxxx.api.infobip.com
SMS_API_KEY=replace-with-provider-api-key
SMS_SENDER_ID=ServiceSMS
APP_PUBLIC_URL=https://truck-dispa.vercel.app

# Optional: allow demo seed on empty DB (never enable on public production)
ALLOW_DEMO_SEED=false

# Optional: protect POST /api/internal/sms-retry for Vercel Cron
CRON_SECRET=replace-with-random-cron-secret

# Public support contact shown on /contact (optional)
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_PHONE=+252XXXXXXXXX
