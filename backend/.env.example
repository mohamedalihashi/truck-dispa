PORT=4000
CLIENT_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
JWT_SECRET=change-me-in-production
DATABASE_URL=postgresql://truck:truckpass@127.0.0.1:5432/truck_dispatch?connection_limit=5&pool_timeout=30

# Gmail OTP (create App Password: Google Account → Security → 2-Step Verification → App passwords)
EMAIL_DEV_MODE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=TruckDispatch <your@gmail.com>
