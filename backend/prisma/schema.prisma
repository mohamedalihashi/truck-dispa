// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

enum UserRole {
  admin
  dispatcher
  customer
  driver

  @@map("user_role")
}

enum TruckStatus {
  Available
  Busy
  Maintenance
  Pending_Verification @map("Pending Verification")
  Unavailable

  @@map("truck_status")
}

enum RequestStatus {
  Pending
  Awaiting_Approval @map("Awaiting Approval")
  Quote_Rejected    @map("Quote Rejected")
  Approved
  Assigned
  Accepted
  Arrived_Pickup @map("Arrived Pickup")
  Loaded
  In_Transit     @map("In Transit")
  Delivered
  Cancelled

  @@map("request_status")
}

enum TripStatus {
  Pending
  Assigned
  Accepted
  Arrived_Pickup @map("Arrived Pickup")
  Loaded
  In_Transit     @map("In Transit")
  Delivered
  Cancelled
  Delayed

  @@map("trip_status")
}

enum PaymentStatus {
  Pending
  Partial
  Paid
  Failed
  Refunded

  @@map("payment_status")
}

enum EarningRole {
  driver
  dispatcher
  platform

  @@map("earning_role")
}

enum EarningStatus {
  Available
  PaidOut

  @@map("earning_status")
}

// ─── Models ──────────────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  phone        String?  @unique
  avatarUrl    String?  @map("avatar_url")
  avatarPublicId String? @map("avatar_public_id")
  nationalIdNumber String? @unique @map("national_id_number")
  driverLicense String? @map("driver_license")
  driverLicenseUrl String? @map("driver_license_url")
  driverLicensePublicId String? @map("driver_license_public_id")
  driverImageUrl String? @map("driver_image_url")
  driverImagePublicId String? @map("driver_image_public_id")
  status       String   @default("Active")
  isSuperAdmin Boolean  @default(false) @map("is_super_admin")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  failedLoginAttempts Int @default(0) @map("failed_login_attempts")
  lockedUntil DateTime? @map("locked_until") @db.Timestamptz()
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  truck                 Truck?
  cargoRequestsAsCustomer  CargoRequest[] @relation("CargoRequestCustomer")
  cargoRequestsAsDriver    CargoRequest[] @relation("CargoRequestDriver")
  cargoRequestsAsDispatcher CargoRequest[] @relation("CargoRequestDispatcher")
  tripsAsCustomer       Trip[]         @relation("TripCustomer")
  tripsAsDriver         Trip[]         @relation("TripDriver")
  tripsAsDispatcher     Trip[]         @relation("TripDispatcher")
  notifications         Notification[]
  paymentsAsCustomer    Payment[]      @relation("PaymentCustomer")
  earningsAsRecipient   Earning[]      @relation("EarningRecipient")
  auditLogs             AuditLog[]
  feedbackAsCustomer    TripFeedback[] @relation("FeedbackCustomer")
  feedbackAsDriver      TripFeedback[] @relation("FeedbackDriver")
  dispatcherProfile     DispatcherProfile? @relation("DispatcherProfileOwner")
  verifiedDispatcherProfiles DispatcherProfile[] @relation("DispatcherProfileVerifier")
  customerProfile       CustomerProfile?

  @@map("users")
}

model CustomerProfile {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  customerType String   @map("customer_type")
  city         String
  address      String?
  profilePhotoUrl String? @map("profile_photo_url")
  profilePhotoPublicId String? @map("profile_photo_public_id")
  companyName  String?  @map("company_name")
  companyPhone String?  @map("company_phone")
  companyAddress String? @map("company_address")
  businessRegistrationNumber String? @map("business_registration_number")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerType, city])
  @@map("customer_profiles")
}

model DispatcherProfile {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  dispatcherCode        String   @unique @map("dispatcher_code")
  nationalIdNumber      String   @unique @map("national_id_number")
  nationalIdFrontUrl    String   @map("national_id_front_url")
  nationalIdBackUrl     String   @map("national_id_back_url")
  profilePhotoUrl       String   @map("profile_photo_url")
  dateOfBirth           DateTime @map("date_of_birth") @db.Date
  gender                String
  city                  String
  address               String
  cvUrl                 String   @map("cv_url")
  yearsOfExperience     Int      @map("years_of_experience")
  assignedRegion        String   @map("assigned_region")
  workShift             String   @map("work_shift")
  emergencyContactName  String   @map("emergency_contact_name")
  emergencyContactPhone String   @map("emergency_contact_phone")
  commissionPercentage  Decimal  @default(0) @map("commission_percentage") @db.Decimal(5, 2)
  verificationStatus    String   @default("Pending") @map("verification_status")
  verifiedBy            String?  @map("verified_by") @db.Uuid
  verifiedAt            DateTime? @map("verified_at") @db.Timestamptz()
  accountStatus         String   @default("Active") @map("account_status")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user     User  @relation("DispatcherProfileOwner", fields: [userId], references: [id], onDelete: Cascade)
  verifier User? @relation("DispatcherProfileVerifier", fields: [verifiedBy], references: [id], onDelete: SetNull)

  @@index([assignedRegion, accountStatus])
  @@index([verificationStatus])
  @@map("dispatcher_profiles")
}

model TruckType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("truck_types")
}

model Truck {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  truckNumber String      @map("truck_number")
  plateNumber String      @unique @map("plate_number")
  capacity    String
  truckType   String      @map("truck_type")
  photoUrl1   String?     @map("photo_url_1")
  photoUrl2   String?     @map("photo_url_2")
  photoPublicId1 String?   @map("photo_public_id_1")
  photoPublicId2 String?   @map("photo_public_id_2")
  registrationDocumentUrl String? @map("registration_document_url")
  registrationDocumentPublicId String? @map("registration_document_public_id")
  documentUrls String[]   @default([]) @map("document_urls")
  driverId    String      @unique @map("driver_id") @db.Uuid
  status      TruckStatus @default(Available)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  driver        User           @relation(fields: [driverId], references: [id], onDelete: Cascade)
  cargoRequests CargoRequest[]
  trips         Trip[]

  @@map("trucks")
}

model CargoRequest {
  id                    String        @id
  customerId            String        @map("customer_id") @db.Uuid
  pickup                String
  destination           String
  truckType             String        @map("truck_type")
  weight                String
  description           String
  receiver              String?
  sender                String?
  customerRole          String?       @map("customer_role")
  senderName            String?       @map("sender_name")
  senderPhone           String?       @map("sender_phone")
  receiverName          String?       @map("receiver_name")
  receiverPhone         String?       @map("receiver_phone")
  fromRegion            String?       @map("from_region")
  fromDistrict          String?       @map("from_district")
  fromNeighborhood      String?       @map("from_neighborhood")
  toRegion              String?       @map("to_region")
  toDistrict            String?       @map("to_district")
  toNeighborhood        String?       @map("to_neighborhood")
  submissionKey         String?       @unique @map("submission_key") @db.Uuid
  specialInstructions   String?       @map("special_instructions")
  preferredPickupDate   DateTime?     @map("preferred_pickup_date") @db.Date
  quotedPrice           Decimal?      @map("quoted_price") @db.Decimal(12, 2)
  quotedEstimatedTime   String?       @map("quoted_estimated_time")
  quoteNotes            String?       @map("quote_notes")
  quotedAt              DateTime?     @map("quoted_at") @db.Timestamptz()
  quoteVersion          Int           @default(0) @map("quote_version")
  customerDecisionAt    DateTime?     @map("customer_decision_at") @db.Timestamptz()
  customerDecisionNote  String?       @map("customer_decision_note")
  status                RequestStatus @default(Pending)
  driverId              String?       @map("driver_id") @db.Uuid
  truckId               String?       @map("truck_id") @db.Uuid
  dispatcherId          String?       @map("dispatcher_id") @db.Uuid
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  customer   User   @relation("CargoRequestCustomer", fields: [customerId], references: [id])
  driver     User?  @relation("CargoRequestDriver", fields: [driverId], references: [id])
  dispatcher User?  @relation("CargoRequestDispatcher", fields: [dispatcherId], references: [id])
  truck      Truck? @relation(fields: [truckId], references: [id])
  trips      Trip[]

  @@index([status], map: "idx_cargo_requests_status")
  @@map("cargo_requests")
}

model Trip {
  id               String     @id
  cargoRequestId   String?    @map("cargo_request_id")
  customerId       String     @map("customer_id") @db.Uuid
  driverId         String?    @map("driver_id") @db.Uuid
  dispatcherId     String?    @map("dispatcher_id") @db.Uuid
  truckId          String?    @map("truck_id") @db.Uuid
  pickup           String
  destination      String
  distance         String?
  estimatedTime    String?    @map("estimated_time")
  status           TripStatus @default(Pending)
  fare             Decimal    @default(0) @db.Decimal(12, 2)
  deliveryProofUrl String?    @map("delivery_proof_url")
  signatureUrl     String?    @map("signature_url")
  deliveryConfirmedAt DateTime? @map("delivery_confirmed_at") @db.Timestamptz()
  lastLat          Float?     @map("last_lat")
  lastLng          Float?     @map("last_lng")
  lastLocationAt   DateTime?  @map("last_location_at") @db.Timestamptz()
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  cargoRequest CargoRequest? @relation(fields: [cargoRequestId], references: [id])
  customer     User          @relation("TripCustomer", fields: [customerId], references: [id])
  driver       User?         @relation("TripDriver", fields: [driverId], references: [id])
  dispatcher   User?         @relation("TripDispatcher", fields: [dispatcherId], references: [id])
  truck        Truck?        @relation(fields: [truckId], references: [id])
  payments     Payment[]
  earnings     Earning[]
  feedback     TripFeedback?
  feedbackToken DeliveryFeedbackToken?
  locationPoints TripLocationPoint[]

  @@index([status], map: "idx_trips_status")
  @@map("trips")
}

model TripLocationPoint {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId     String   @map("trip_id")
  lat        Float
  lng        Float
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz()

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, recordedAt], map: "idx_trip_location_points_trip")
  @@map("trip_location_points")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read], map: "idx_notifications_user")
  @@map("notifications")
}

model Payment {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId                String?       @map("trip_id")
  customerId            String?       @map("customer_id") @db.Uuid
  amount                Decimal       @db.Decimal(12, 2)
  amountPaid            Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  status                PaymentStatus @default(Pending)
  method                String?       @default("waafipay")
  currency              String?       @default("SLSH")
  referenceId           String?       @unique @map("reference_id")
  description           String?
  provider              String?       @default("waafipay")
  providerTransactionId String?       @map("provider_transaction_id")
  providerResponse      Json?         @map("provider_response")
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  trip     Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)
  customer User? @relation("PaymentCustomer", fields: [customerId], references: [id])
  earnings Earning[]

  @@map("payments")
}

model Earning {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId       String?       @map("payment_id") @db.Uuid
  tripId          String?       @map("trip_id")
  recipientId     String?       @map("recipient_id") @db.Uuid
  recipientRole   EarningRole   @map("recipient_role")
  amount          Decimal       @db.Decimal(12, 2)
  percent         Decimal       @db.Decimal(5, 2)
  currency        String?       @default("SLSH")
  status          EarningStatus @default(Available)
  payoutMethod    String?       @map("payout_method")
  payoutReference String?       @map("payout_reference")
  paidOutAt       DateTime?     @map("paid_out_at") @db.Timestamptz()
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  recipient User?    @relation("EarningRecipient", fields: [recipientId], references: [id])

  @@index([recipientId, status], map: "idx_earnings_recipient")
  @@map("earnings")
}

model Setting {
  key       String   @id
  value     Json     @default("{}")
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  @@map("settings")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("actor_id") @db.Uuid
  action      String
  entityType  String?  @map("entity")
  entityId    String?  @map("entity_id")
  description String?
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  status      String   @default("Success")
  meta        Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], map: "idx_audit_logs_user_created")
  @@index([action, createdAt], map: "idx_audit_logs_action_created")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@map("audit_logs")
}

model VerificationCode {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String
  codeHash  String    @map("code")
  purpose   String
  payload   Json?
  attempts  Int       @default(0)
  maxAttempts Int     @default(5) @map("max_attempts")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([email, purpose, expiresAt], map: "idx_verification_codes_lookup")
  @@map("verification_codes")
}

model TripFeedback {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId        String   @unique @map("trip_id")
  customerId    String   @map("customer_id") @db.Uuid
  driverId      String?  @map("driver_id") @db.Uuid
  rating        Int
  productRating Int?     @map("product_rating")
  driverBehaviourRating Int? @map("driver_behaviour_rating")
  deliverySpeedRating Int? @map("delivery_speed_rating")
  cargoConditionRating Int? @map("cargo_condition_rating")
  cargoReceivedSafely Boolean? @map("cargo_received_safely")
  reportProblem Boolean @default(false) @map("report_problem")
  complaintStatus String @default("None") @map("complaint_status")
  senderName    String?  @map("sender_name")
  senderPhone   String?  @map("sender_phone")
  receiverName  String?  @map("receiver_name")
  receiverPhone String?  @map("receiver_phone")
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  trip     Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  customer User  @relation("FeedbackCustomer", fields: [customerId], references: [id])
  driver   User? @relation("FeedbackDriver", fields: [driverId], references: [id])

  @@index([driverId], map: "idx_trip_feedback_driver")
  @@map("trip_feedback")
}

model DeliveryFeedbackToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId    String    @unique @map("trip_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([expiresAt, usedAt], map: "idx_delivery_feedback_tokens_validity")
  @@map("delivery_feedback_tokens")
}

model SmsNotification {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType        String    @map("entity_type")
  entityId          String    @map("entity_id")
  event             String
  recipientName     String?   @map("recipient_name")
  recipientPhone    String    @map("recipient_phone")
  message           String
  status            String    @default("Pending")
  providerMessageId String?   @map("provider_message_id")
  failureReason     String?   @map("failure_reason")
  attempts          Int       @default(0)
  nextRetryAt       DateTime? @map("next_retry_at") @db.Timestamptz()
  sentAt            DateTime? @map("sent_at") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([event, recipientPhone, entityType, entityId], map: "uq_sms_event_recipient_entity")
  @@index([status, nextRetryAt], map: "idx_sms_retry_queue")
  @@map("sms_notifications")
}
