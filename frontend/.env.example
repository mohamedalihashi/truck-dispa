VITE_API_URL=/api
VITE_SOCKET_URL=

# Public contact shown on /contact and privacy pages
VITE_SUPPORT_EMAIL=support@truckdispatch.so
VITE_SUPPORT_PHONE=+252 61 XXX XXXX

# Local dev: Vite proxies /api and /socket.io to backend (port 4000).
# Vercel production: same-origin /api (no change needed).

# Optional: Google Maps API key
# VITE_GOOGLE_MAPS_API_KEY=

# Direct backend (skip proxy):
# VITE_API_URL=http://127.0.0.1:4000/api
# VITE_SOCKET_URL=http://127.0.0.1:4000
